# --- Database (PostgreSQL) ---------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/eipsinsight"
# DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/eipsinsight"
# BETTER_AUTH_USE_DIRECT_DATABASE="false"
# PRISMA_SSL_ALLOW_SELF_SIGNED="false"

# --- Auth (Better Auth) ------------------------------------------------------
BETTER_AUTH_SECRET="local-dev-secret-replace-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"

# --- GitHub OAuth ------------------------------------------------------------
GITHUB_CLIENT_ID="your_github_oauth_client_id"
GITHUB_CLIENT_SECRET="your_github_oauth_client_secret"
GITHUB_ACCESS_TOKEN="ghp_your_github_personal_access_token"
# GITHUB_TOKEN="ghp_your_github_personal_access_token"

# --- Google OAuth ------------------------------------------------------------
GOOGLE_CLIENT_ID="your_google_oauth_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_oauth_client_secret"

# --- Email (SMTP) ------------------------------------------------------------
EMAIL_SERVICE="smtp"
EMAIL_HOST="smtp.example.com"
EMAIL_PORT=587
EMAIL_USERNAME="your_smtp_username"
EMAIL_PASSWORD="your_smtp_password"
EMAIL_FROM="noreply@example.com"

# --- Cloudinary (image uploads) ----------------------------------------------
CLOUDINARY_URL="cloudinary://123456789012345:abcdefghijklmnopqrstuvwxyz123456@your_cloud_name"
# CLOUDINARY_UPLOAD_PRESET="your_unsigned_upload_preset"

# --- Redis -------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# --- Stripe (optional) ---------------------------------------------------------
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# --- Ghost CMS (optional) ----------------------------------------------------
# GHOST_API_URL="https://your-ghost-site.com"
# GHOST_CONTENT_API_KEY="your_ghost_content_api_key"
# GHOST_ADMIN_API_KEY="your_ghost_admin_api_key"

# --- Cloudflare (optional) ---------------------------------------------------
# CLOUDFLARE_ACCOUNT_ID="your_account_id"
# CLOUDFLARE_API_TOKEN="your_api_token"

# --- AI / search (optional) --------------------------------------------------
# COHERE_API_KEY="your_cohere_api_key"
# GROQ_API_KEY="your_groq_api_key"   # preferred — free tier, faster, better SQL quality

# --- Client feature flags (optional) -----------------------------------------
# NEXT_PUBLIC_FEATURE_PERSONA_ONBOARDING="false"
# NEXT_PUBLIC_FEATURE_PERSONA_SWITCHER="false"
# NEXT_PUBLIC_FEATURE_PERSONA_NAV_REORDER="false"
# NEXT_PUBLIC_FEATURE_PERSONA_CONTEXT_HEADERS="false"
# NEXT_PUBLIC_FEATURE_PERSONA_NAV_VISIBILITY="true"

# --- API token for oRPC client (optional) ------------------------------------
# NEXT_PUBLIC_API_TOKEN="your_api_token"
